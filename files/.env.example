# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM Inference (required) ───────────────────────────────
# OpenAI-compatible API base URL
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier (must be OpenAI-chat-compatible)
# HuggingFace examples:
#   mistralai/Mistral-7B-Instruct-v0.3
#   meta-llama/Meta-Llama-3-8B-Instruct
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# HuggingFace token (used as API key for HF Inference API)
HF_TOKEN=hf_your_token_here

# ── Environment Server (required by inference runner) ──────
# URL where the environment API is running.
# Docker Compose example: http://env:7860
# Hugging Face Space example: https://your-space-name.hf.space
ENV_URL=https://your-space-name.hf.space
